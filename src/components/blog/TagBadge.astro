---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
---

{href ? (
  <a href={href} class="tag-badge tag-badge--link">#{tag}</a>
) : (
  <span class="tag-badge">#{tag}</span>
)}

<style>
  .tag-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    background: transparent;
    border: 1px solid var(--color-lagoon-spark);
    border-radius: var(--radius-default);
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-lagoon-spark);
    letter-spacing: 0.077em;
    line-height: 1.38;
  }

  .tag-badge--link {
    text-decoration: none;
    transition: background 0.15s;
    cursor: pointer;
  }

  .tag-badge--link:hover {
    background: rgba(52, 252, 255, 0.1);
  }
</style>
