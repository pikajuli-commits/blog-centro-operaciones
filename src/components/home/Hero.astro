---
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      <span>Centro de Operaciones</span>
    </div>

    <h1 class="hero-title">
      Economía, geopolítica<br />
      y scripts <span class="hero-title-accent">What If</span>
    </h1>

    <p class="hero-description">
      Análisis técnico con modelos matemáticos, visualizaciones y videos cortos
      que convierten conceptos complejos en ideas accionables.
    </p>

    <div class="hero-actions">
      <a href="/blog" class="btn-primary">
        Leer artículos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/what-if" class="btn-ghost">
        Explorar What If
      </a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-label">Blog</span>
        <span class="stat-desc">Análisis técnicos</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-label">Economía</span>
        <span class="stat-desc">Guías con LaTeX</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-label">What If</span>
        <span class="stat-desc">Escenarios geopolíticos</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    background: radial-gradient(circle, rgb(6, 16, 90), rgb(0, 5, 46) 79%);
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 4px 16px;
    background: transparent;
    border: 1px solid var(--color-slate-shadow);
    border-radius: var(--radius-default);
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-light-mauve-aura);
    letter-spacing: 0.086em;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-lagoon-spark);
    border-radius: 50%;
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-title {
    font-family: var(--font-headline);
    font-size: clamp(2.2rem, 5.5vw, 59px);
    font-weight: 300;
    color: var(--color-arctic-mist);
    line-height: 1.26;
    margin: 0 0 1.25rem;
    letter-spacing: -0.019em;
  }

  .hero-title-accent {
    color: var(--color-lagoon-spark);
  }

  .hero-description {
    font-size: 1rem;
    color: var(--color-light-mauve-aura);
    max-width: 55ch;
    line-height: 1.65;
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .stat-label {
    font-family: var(--font-headline);
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--color-arctic-mist);
  }

  .stat-desc {
    font-size: 0.75rem;
    color: var(--color-slate-shadow);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 28px;
    background: var(--color-steel-gray);
  }
</style>
