---
---

<section class="hero particles-bg">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Centro de Operaciones
    </div>

    <h1 class="hero-title">
      Economía, geopolítica<br />
      <span class="hero-title-accent">y scripts What If</span>
    </h1>

    <p class="hero-description">
      Análisis técnico con modelos matemáticos, visualizaciones y videos cortos
      que convierten conceptos complejos en ideas accionables.
    </p>

    <div class="hero-actions">
      <a href="/blog" class="btn-primary">
        Leer artículos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/what-if" class="btn-secondary">
        Explorar What If
      </a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-label">Blog</span>
        <span class="stat-desc">Análisis técnicos</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-label">Economía</span>
        <span class="stat-desc">Guías con LaTeX</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-label">What If</span>
        <span class="stat-desc">Escenarios geopolíticos</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    background: radial-gradient(
      ellipse 80% 60% at 50% -10%,
      rgba(30, 144, 255, 0.12) 0%,
      transparent 70%
    );
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background: rgba(30, 144, 255, 0.1);
    border: 1px solid rgba(30, 144, 255, 0.25);
    border-radius: 999px;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--color-electric-blue);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-electric-blue);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-title {
    font-family: var(--font-headline);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--color-nebula-white);
    line-height: 1.15;
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero-title-accent {
    background: linear-gradient(135deg, var(--color-electric-blue) 0%, var(--color-glow-blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 1.1rem;
    color: var(--color-stellar-silver);
    max-width: 55ch;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .stat-label {
    font-family: var(--font-headline);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-nebula-white);
  }

  .stat-desc {
    font-size: 0.78rem;
    color: rgba(192, 200, 216, 0.55);
  }

  .stat-divider {
    width: 1px;
    height: 28px;
    background: rgba(30, 144, 255, 0.2);
  }
</style>
