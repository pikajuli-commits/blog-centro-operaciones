---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-logo">
        <span style="color: var(--color-electric-blue)">[</span>
        <span style="color: var(--color-nebula-white)">CO</span>
        <span style="color: var(--color-electric-blue)">]</span>
      </span>
      <span class="footer-copy">Centro de Operaciones &copy; {year}</span>
    </div>
    <nav class="footer-nav" aria-label="Footer">
      <a href="/blog">Blog</a>
      <a href="/what-if">What If</a>
      <a href="/economia">Economía</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(30, 144, 255, 0.1);
    margin-top: 5rem;
    padding: 2rem 0;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 1rem;
  }

  .footer-copy {
    font-size: 0.85rem;
    color: rgba(192, 200, 216, 0.5);
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
  }

  .footer-nav a {
    font-size: 0.85rem;
    color: rgba(192, 200, 216, 0.5);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: var(--color-electric-blue);
  }
</style>
