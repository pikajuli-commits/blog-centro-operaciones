---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-logo">
        <span style="color: var(--color-lagoon-spark)">[</span>
        <span style="color: var(--color-arctic-mist)">CO</span>
        <span style="color: var(--color-lagoon-spark)">]</span>
      </span>
      <span class="footer-copy">Centro de Operaciones &copy; {year}</span>
    </div>
    <nav class="footer-nav" aria-label="Footer">
      <a href="/blog">Blog</a>
      <a href="/what-if">What If</a>
      <a href="/economia">Economía</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-slate-shadow);
    margin-top: 80px;
    padding: 2rem 0;
    background: var(--color-midnight-ink);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.086em;
  }

  .footer-copy {
    font-size: 0.85rem;
    color: var(--color-slate-shadow);
  }

  .footer-nav {
    display: flex;
    gap: 0;
  }

  .footer-nav a {
    font-size: 0.85rem;
    color: var(--color-slate-shadow);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: var(--color-lagoon-spark);
  }
</style>
