---
const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/what-if', label: 'What If' },
  { href: '/economia', label: 'Economía' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-header">
  <nav class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Inicio">
      <span class="logo-bracket">[</span>
      <span class="logo-text">CO</span>
      <span class="logo-bracket">]</span>
    </a>

    <ul class="nav-links" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`nav-link ${currentPath.startsWith(href) ? 'nav-link--active' : ''}`}
            aria-current={currentPath.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <a href="/rss.xml" class="nav-rss" aria-label="Feed RSS" title="RSS Feed">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
      </svg>
    </a>
  </nav>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-midnight-ink);
    border-bottom: 1px solid var(--color-slate-shadow);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-logo {
    text-decoration: none;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.086em;
    margin-right: auto;
    transition: opacity 0.2s;
  }

  .nav-logo:hover { opacity: 0.7; }

  .logo-bracket { color: var(--color-lagoon-spark); }
  .logo-text { color: var(--color-arctic-mist); margin: 0 2px; }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: block;
    padding: 20px;
    color: var(--color-arctic-mist);
    text-decoration: none;
    font-size: 0.9rem;
    font-family: var(--font-body);
    font-weight: 400;
    border: 1px solid transparent;
    transition: border-color 0.15s, color 0.15s;
  }

  .nav-link:hover {
    border-color: var(--color-arctic-mist);
  }

  .nav-link--active {
    color: var(--color-lagoon-spark);
    border-color: var(--color-lagoon-spark);
  }

  .nav-rss {
    color: var(--color-slate-shadow);
    text-decoration: none;
    padding: 20px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }

  .nav-rss:hover { color: var(--color-lagoon-spark); }

  @media (max-width: 600px) {
    .nav-link { padding: 12px 10px; font-size: 0.8rem; }
    .nav-rss { padding: 12px; }
  }
</style>
