---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/blog/TagBadge.astro';
import VideoEmbed from '../components/media/VideoEmbed.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  heroImage?: string;
  videoUrl?: string;
  latex?: boolean;
  collection: 'blog' | 'what-if' | 'economia';
  scenario?: string;
  level?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  heroImage,
  videoUrl,
  latex,
  collection,
  scenario,
  level,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const collectionLabels: Record<string, string> = {
  blog: 'Análisis',
  'what-if': 'What If',
  economia: 'Economía',
};
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  pubDate={pubDate}
  type="article"
>
  <article class="post-wrapper">
    <header class="post-header">
      <!-- Breadcrumb -->
      <nav class="post-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href={`/${collection}`}>{collectionLabels[collection]}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{title}</span>
      </nav>

      <!-- Tags -->
      <div class="post-tags">
        {tags.map(tag => <TagBadge tag={tag} />)}
        {level && <span class="post-level">{level}</span>}
      </div>

      <!-- Título -->
      <h1 class="post-title">{title}</h1>

      {scenario && <p class="post-scenario">{scenario}</p>}

      <p class="post-description">{description}</p>

      <!-- Metadata -->
      <div class="post-meta">
        <time datetime={pubDate.toISOString()} class="post-date">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          {formattedDate}
        </time>
        {updatedDate && (
          <span class="post-updated">
            (Actualizado: {updatedDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })})
          </span>
        )}
        {latex && (
          <span class="post-latex-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
            </svg>
            Incluye LaTeX
          </span>
        )}
      </div>
    </header>

    <!-- Video embed (si existe) -->
    {videoUrl && (
      <VideoEmbed url={videoUrl} title={`Video: ${title}`} />
    )}

    <!-- Contenido MDX -->
    <div class="prose prose-sideral post-content">
      <slot />
    </div>

    <!-- Footer del post -->
    <footer class="post-footer">
      <a href={`/${collection}`} class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Volver a {collectionLabels[collection]}
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-wrapper {
    max-width: 780px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(30, 144, 255, 0.1);
  }

  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgba(192, 200, 216, 0.45);
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
  }

  .post-breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-breadcrumb a:hover {
    color: var(--color-electric-blue);
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    align-items: center;
  }

  .post-level {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    padding: 0.2rem 0.5rem;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.25);
    border-radius: 0.25rem;
    color: #f59e0b;
    text-transform: uppercase;
  }

  .post-title {
    font-family: var(--font-headline);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-nebula-white);
    line-height: 1.2;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .post-scenario {
    font-size: 1rem;
    color: var(--color-electric-blue);
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .post-description {
    font-size: 1.05rem;
    color: var(--color-stellar-silver);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-date {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: rgba(192, 200, 216, 0.5);
    font-family: var(--font-mono);
  }

  .post-updated {
    font-size: 0.8rem;
    color: rgba(192, 200, 216, 0.4);
    font-family: var(--font-mono);
  }

  .post-latex-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-electric-blue);
    background: rgba(30, 144, 255, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }

  .post-content {
    margin-bottom: 3rem;
  }

  .post-footer {
    padding-top: 1.5rem;
    border-top: 1px solid rgba(30, 144, 255, 0.1);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: rgba(192, 200, 216, 0.55);
    text-decoration: none;
    transition: color 0.15s;
    font-family: var(--font-body);
  }

  .back-link:hover {
    color: var(--color-electric-blue);
  }
</style>
