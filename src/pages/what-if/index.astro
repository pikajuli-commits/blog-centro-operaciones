---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('what-if', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="What If"
  description="Scripts de economía especulativa y geopolítica: ¿Qué pasaría si...? Escenarios posibles, consecuencias analizadas."
>
  <section class="list-page">
    <div class="list-inner">
      <header class="list-header">
        <div class="list-tag">Scripts especulativos</div>
        <h1 class="list-title">What If</h1>
        <p class="list-subtitle">
          Ejercicios de economía y geopolítica especulativa.
          ¿Qué pasaría si un evento improbable ocurriera hoy?
        </p>
      </header>

      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map(post => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              collection="what-if"
              tags={post.data.tags}
              videoUrl={post.data.videoUrl}
              latex={post.data.latex}
              scenario={post.data.scenario}
              level={undefined}
            />
          ))}
        </div>
      ) : (
        <p class="empty">Próximamente — escenarios en construcción.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .list-page { padding: 3rem 0 5rem; }
  .list-inner { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .list-header { margin-bottom: 2.5rem; }
  .list-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-electric-blue);
    background: rgba(30, 144, 255, 0.1);
    border: 1px solid rgba(30, 144, 255, 0.2);
    border-radius: 0.3rem;
    padding: 0.2rem 0.6rem;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .list-title {
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-nebula-white);
    margin-bottom: 0.5rem;
  }
  .list-subtitle {
    color: var(--color-stellar-silver);
    font-size: 1rem;
    max-width: 55ch;
    line-height: 1.6;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }
  .empty {
    color: rgba(192, 200, 216, 0.4);
    font-style: italic;
    padding: 2rem 0;
  }
</style>
